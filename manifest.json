{
    "manifest_version": 3,
    "name": "Form-Filler",
    "description": "Fills basic information in google forms automatically",
    "version": "0.0.1",
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "./content.js"
            ]
        }
    ],
    "permissions":[
        "activeTab",
        "tabs"
    ]
}